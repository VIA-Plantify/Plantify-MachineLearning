{
  "name": "Mal Dev GPU",
  "dockerComposeFile": "../../docker-compose.gpu.dev.yml",
  "service": "maldev-gpu",
  "workspaceFolder": "/workspace",
  "shutdownAction": "none",
  "updateRemoteUserUID": false,
  "postCreateCommand": "chmod +x /workspace/.scripts/*.sh && bash /workspace/.scripts/setup-dev.sh",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
}